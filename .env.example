# Service: epr-facade-account-microservice
EprFacadeAccountMicroservice__AzureADB2C__ClientSecret=
EprFacadeAccountMicroservice__MessagingConfig__ApiKey=

# Service: epr-pom-api-submission-status
EprPomApiSubmissionStatus__Database__AccountKey=

# Service: waste-obligations
# key format is part1-part2-part3
# part 1 can be a text string (no spaces)
# parts 2 and 3 are 00000000-0000-0000-0000-000000000000
GovukNotify__ApiKey=

# Service: waste-obligations-frontend (cdp-waste-obligations-frontend-signin-dev)
# Required for Docker sign-in (obligations profile). Maps to AZURE_AD_B2C_* in compose.yml.
WasteObligationsFrontend__AzureAdB2C__ClientId=1a512714-ecd4-44f1-ad60-8229da59fb52
WasteObligationsFrontend__AzureAdB2C__ClientSecret=

# npm run dev: configure waste-obligations-frontend/.env (not this file):
#   AZURE_AD_B2C_CLIENT_SECRET — same B2C app as above
#   BACKEND_ACCOUNT_API_* — Wiremock at http://localhost:9090/oauth2/v2.0/token (see compose.yml)
#     or real MO-119 Azure credentials for client credentials to login.microsoftonline.com

# EPR packaging URLs for waste-obligations-frontend are set in compose.yml (https://localhost:7084/report-data).
# Override here only if your packaging frontend runs elsewhere.
