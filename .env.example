# Collect secrets from Keyvault or a fellow developer

# Service: epr-calculator-frontend
EprCalculatorFrontend__AzureAd__ClientSecret=

# Service: epr-common-data-api
EprCommonDataApi__ConnectionStrings__SynapseDatabase=
EprCommonDataApi__Dll=EPR.CommonDataService.Api.dll

# Service: epr-packaging-frontend
EprPackagingFrontend__AzureADB2C__ClientSecret=
